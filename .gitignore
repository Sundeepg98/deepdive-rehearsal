# build/runtime cruft — the deliverable itself IS committed (ready to open)
__pycache__/
*.pyc
node_modules/
*.tar.gz
*.zip
.DS_Store
/tmp/

# salvage bloat-guard -- generated test output must never land on master.
# The v300/v308 branches committed 78K-134K lines of report JSON + multi-MB
# PNG screenshots; visual-enhancements added e2e_report_*.json. Keep them out
# so a future file-extract/salvage can't reintroduce the bloat.
test/reports/
deploy_temp/
test/scan_report.json
e2e_report_*.json
dist/
design-tokens/build/
src/tokens.generated.css
# Generated by compileTopicsPlugin at buildStart; app.js includes it, build regenerates it.
# Compiled output from src/topics-md/*.md -- the markdown is the source; the build regenerates
# these so they are never committed. All slices + include bundles live under _generated/ (one line
# covers every current and future topic), so adding a topic needs no .gitignore edit. The registry
# partial keeps its own path because app.js includes it by that name.
src/topics/_generated/
src/topics/_generated-registry.js

# visual-trainer subproject (own npm project; only sources + the built pilot are tracked)
visual-trainer/node_modules/
visual-trainer/dist/

# generated visual kit (built by tools/build-visual-kit.mjs)
src/scripts/visuals/

# Playwright MCP session scratch (browser snapshots), not source
.playwright-mcp/

# scratch probes + screenshots from the entry-architecture work (generated; never commit)
_probe/
_audit/shots/
