   {
    "topic": "slos",
    "pivots": [
     {
      "pivW": 704,
      "sumScrollW": 1411,
      "sumClientW": 702,
      "overflow": 709,
      "chipText": "→ a proportion of good events over valid events, measured near the user, that moves with user happiness\nNot CPU/memory (internal, weakly correlated with pain); the test is \"if this SLI is met, are users happy?\" -- and latency SLIs use percentiles under a threshold, never averages.",
      "chipLen": 281,
      "chipW": 1346,
      "chipNowrap": "nowrap",
      "paText": "",
      "paLen": 0,
      "paEmpty": true,
      "pqW": 37,
      "pivOverflowHidden": "hidden"
     },
     {
      "pivW": 704,
      "sumScrollW": 1246,
      "sumClientW": 702,
      "overflow": 544,
      "chipText": "→ multi-window multi-burn-rate: a fast burn pages, a slow burn tickets\nTies alerting to user-impact-over-time (the budget), not an arbitrary threshold -- so a harmless spike doesn't page and a slow leak still gets caught, fixing both noise and gaps.",
      "chipLen": 249,
      "chipW": 1189,
      "chipNowrap": "nowrap",
      "paText": "",
      "paLen": 0,
      "paEmpty": true,
      "pqW": 29,
