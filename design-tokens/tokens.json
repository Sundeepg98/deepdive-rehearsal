{
  "$description": "deepdive-rehearsal design tokens (W3C DTCG). 3-tier primitives -> semantic. Models the audited gaps (typography, z-index) + the motion system. The app's superior palette/shadows/spacing stay as-is.",

  "size": { "font": { "$type": "dimension",
    "0": { "$value": "12px" }, "1": { "$value": "13px" }, "2": { "$value": "14px" },
    "3": { "$value": "16px" }, "4": { "$value": "18px" }, "5": { "$value": "21px" },
    "6": { "$value": "24px" }, "7": { "$value": "32px" }, "8": { "$value": "48px" } } },

  "line-height": { "$type": "number", "tight": { "$value": 1.2 }, "snug": { "$value": 1.4 }, "normal": { "$value": 1.6 } },

  "font-weight": { "$type": "number",
    "regular": { "$value": 400 }, "medium": { "$value": 500 }, "semibold": { "$value": 640 }, "bold": { "$value": 720 } },

  "font-size": { "$type": "dimension", "$description": "semantic type roles (Material 3), 7 roles replacing 40 ad-hoc sizes",
    "caption": { "$value": "{size.font.0}" }, "small": { "$value": "{size.font.1}" }, "body": { "$value": "{size.font.2}" },
    "body-lg": { "$value": "{size.font.3}" }, "title": { "$value": "{size.font.4}" }, "heading": { "$value": "{size.font.5}" }, "display": { "$value": "{size.font.7}" } },

  "z": { "$type": "number", "$description": "semantic z-index tiers, 7 layers replacing 20 ad-hoc values",
    "base": { "$value": 0 }, "raised": { "$value": 10 }, "dropdown": { "$value": 200 }, "sticky": { "$value": 400 },
    "overlay": { "$value": 1000 }, "modal": { "$value": 1200 }, "toast": { "$value": 9999 } },

  "duration": { "$type": "duration", "$description": "MOTION system -- semantic durations (was 20+ ad-hoc fractional-second values)",
    "instant": { "$value": "0ms" }, "quick": { "$value": "150ms" }, "moderate": { "$value": "250ms" }, "slow": { "$value": "400ms" } },

  "ease": { "$description": "MOTION system -- semantic easing roles (Material 3 curves), on top of Open Props' 83 primitive curves",
    "standard": { "$value": "cubic-bezier(0.2, 0, 0, 1)" }, "emphasized": { "$value": "cubic-bezier(0.3, 0, 0, 1)" },
    "decelerate": { "$value": "cubic-bezier(0, 0, 0, 1)" }, "accelerate": { "$value": "cubic-bezier(0.3, 0, 1, 1)" } }
}
