  "font-size": {
    "$type": "dimension",
    "$description": "semantic type roles covering the app range; 40 ad-hoc sizes collapse onto these",
    "nano": {
      "$value": "{size.font.9}"
    },
    "micro": {
      "$value": "{size.font.11}"
    },
    "caption": {
      "$value": "{size.font.12}"
