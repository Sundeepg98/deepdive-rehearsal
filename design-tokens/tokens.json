  "duration": {
    "$type": "duration",
    "$description": "MOTION system -- semantic durations (was 20+ ad-hoc fractional-second values)",
    "instant": {
      "$value": "0ms"
    },
    "quick": {
      "$value": "150ms"
    },
    "moderate": {
      "$value": "250ms"
    },
    "slow": {
      "$value": "400ms"
    }
  },
  "ease": {
    "$description": "MOTION system -- semantic easing roles (Material 3 curves), on top of Open Props' 83 primitive curves",
    "standard": {
      "$value": "cubic-bezier(0.2, 0, 0, 1)"
    },
    "emphasized": {
      "$value": "cubic-bezier(0.3, 0, 0, 1)"
    },
    "decelerate": {
      "$value": "cubic-bezier(0, 0, 0, 1)"
    },
    "accelerate": {
      "$value": "cubic-bezier(0.3, 0, 1, 1)"
    }
  }
}